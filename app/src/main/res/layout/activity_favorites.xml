<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/favoritesRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".FavoritesActivity">

    <TextView
        android:id="@+id/txtFavoritesTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/favorites_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- List View for Favorites -->
    <ListView
        android:id="@+id/listFavorites"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/txtFavoritesTitle"
        app:layout_constraintBottom_toTopOf="@id/bottomNavFavorites"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp" />

    <!-- Empty State Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardEmptyFavorites"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/txtFavoritesTitle"
        app:layout_constraintBottom_toTopOf="@id/bottomNavFavorites"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <ImageView
                android:id="@+id/imgHeart"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:contentDescription="@string/favorites_title"
                android:src="@android:drawable/btn_star_big_off"
                tools:ignore="ImageContrastCheck" />

            <TextView
                android:id="@+id/txtEmptyTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/favorites_empty_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/txtEmptySubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:paddingHorizontal="18dp"
                android:text="@string/favorites_empty_subtitle"
                android:textColor="#757575"
                android:textSize="14sp" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNavFavorites"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@android:color/white"
        android:padding="8dp"
        android:baselineAligned="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/navHomeFav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_home"
            android:textSize="12sp"
            android:textColor="@android:color/black"
            app:drawableTopCompat="@android:drawable/ic_menu_view"
            app:drawableTint="@android:color/black"
            android:drawablePadding="2dp" />

        <TextView
            android:id="@+id/navFavoritesFav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_favorites"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            app:drawableTopCompat="@android:drawable/btn_star_big_on"
            app:drawableTint="@android:color/black"
            android:drawablePadding="2dp" />

        <TextView
            android:id="@+id/navBudgetFav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_budget"
            android:textSize="12sp"
            android:textColor="@android:color/black"
            app:drawableTopCompat="@android:drawable/ic_menu_sort_by_size"
            app:drawableTint="@android:color/black"
            android:drawablePadding="2dp" />

        <TextView
            android:id="@+id/navProfileFav"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_profile"
            android:textSize="12sp"
            android:textColor="@android:color/black"
            app:drawableTopCompat="@android:drawable/ic_menu_myplaces"
            app:drawableTint="@android:color/black"
            android:drawablePadding="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>