<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".HomeActivity">

    <!-- Title -->
    <TextView
        android:id="@+id/txtHomeTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/home_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Search Bar -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilLocationSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="@string/search_hint"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusBottomEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtHomeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="488dp"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtLocationSearch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="10dp"
            android:gravity="center_vertical"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="@android:color/black"
            android:textColorHint="#313033" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Category Label -->
    <TextView
        android:id="@+id/txtCategories"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/categories"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/tilLocationSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp" />

    <!-- Category Buttons Row 1 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCategoryHousing"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/category_housing"
        app:icon="@drawable/ic_home"
        app:iconPadding="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtCategories"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnCategoryFood"
        app:layout_constraintWidth_max="320dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCategoryFood"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/category_food"
        app:icon="@drawable/ic_food"
        app:iconPadding="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/txtCategories"
        app:layout_constraintStart_toEndOf="@id/btnCategoryHousing"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp" />

    <!-- Category Buttons Row 2 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCategoryJobs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/category_jobs"
        app:icon="@drawable/ic_work"
        app:iconPadding="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnCategoryHousing"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnCategoryUtilities"
        app:layout_constraintWidth_max="320dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCategoryUtilities"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/category_utilities"
        app:icon="@drawable/ic_utilities"
        app:iconPadding="8dp"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnCategoryFood"
        app:layout_constraintStart_toEndOf="@id/btnCategoryJobs"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="320dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp" />

    <!-- Resources Nearby Header -->
    <TextView
        android:id="@+id/txtResourcesNearby"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/resources_nearby"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toBottomOf="@id/btnCategoryJobs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" android:layout_marginTop="18dp" />

    <!-- List Placeholder -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResourcesNearby"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="12dp"
        tools:listitem="@android:layout/simple_list_item_2"
        app:layout_constraintTop_toBottomOf="@id/txtResourcesNearby"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        android:layout_marginTop="10dp" />

    <!-- Bottom Navigation (UI-only) -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@android:color/white"
        android:padding="8dp"
        android:baselineAligned="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Home -->
        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_home"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            app:drawableTopCompat="@drawable/ic_view"
            app:drawableTint="@android:color/black"
            android:drawablePadding="2dp" />

        <!-- Favorites -->
        <TextView
            android:id="@+id/navFavorites"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_favorites"
            android:textSize="12sp"
            android:textColor="@android:color/black"
            app:drawableTopCompat="@drawable/ic_favorites"
            app:drawableTint="@android:color/black"
            android:drawablePadding="2dp" />

        <!-- Budget -->
        <TextView
            android:id="@+id/navBudget"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_budget"
            android:textSize="12sp"
            android:textColor="@android:color/black"
            app:drawableTopCompat="@drawable/ic_sort"
            app:drawableTint="@android:color/black"
            android:drawablePadding="2dp" />

        <!-- Profile -->
        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_profile"
            android:textSize="12sp"
            android:textColor="@android:color/black"
            app:drawableTopCompat="@drawable/ic_person"
            app:drawableTint="@android:color/black"
            android:drawablePadding="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>