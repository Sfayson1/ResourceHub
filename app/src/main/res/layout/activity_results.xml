<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    tools:context=".ResultsActivity"
    tools:ignore="VisualLintBounds">

    <TextView
        android:id="@+id/txtResultsTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/results"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/txtResultsSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/showing_resources"
        android:textColor="#757575"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtResultsTitle" />

    <ListView
        android:id="@+id/listResources"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/txtResultsSubtitle"
        app:layout_constraintBottom_toTopOf="@id/bottomNavResults"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"/>

    <!-- Bottom Nav -->
    <LinearLayout
        android:id="@+id/bottomNavResults"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@android:color/white"
        android:padding="8dp"
        android:baselineAligned="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/navHomeResults"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_home"
            android:textSize="12sp"
            app:drawableTopCompat="@android:drawable/ic_menu_view"
            android:drawablePadding="2dp"/>

        <TextView
            android:id="@+id/navFavoritesResults"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_favorites"
            android:textSize="12sp"
            app:drawableTopCompat="@android:drawable/btn_star_big_off"
            android:drawablePadding="2dp"/>

        <TextView
            android:id="@+id/navBudgetResults"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_budget"
            android:textSize="12sp"
            app:drawableTopCompat="@android:drawable/ic_menu_sort_by_size"
            android:drawablePadding="2dp"/>

        <TextView
            android:id="@+id/navProfileResults"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_profile"
            android:textSize="12sp"
            app:drawableTopCompat="@android:drawable/ic_menu_myplaces"
            android:drawablePadding="2dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>